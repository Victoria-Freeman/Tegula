<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/tegula_dialog_bg"
    android:orientation="vertical"
    android:padding="@dimen/tegula_spacing_lg">

    <TextView
        android:id="@+id/tegula_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/tegula_text_primary"
        android:textSize="@dimen/tegula_text_md"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/tegula_spacing_md" />

    <LinearLayout
        android:id="@+id/tegula_dialog_rows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
